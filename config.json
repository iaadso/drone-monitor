    "real_drone_integration": {
        "_comment": "真实无人机接入配置",
        "enabled": false,
        "api_endpoints": {
            "register": "POST /api/drones/register",
            "heartbeat": "POST /api/drones/{drone_id}",
            "patrol_data": "POST /api/drones/{drone_id}",
            "query": "GET /api/drones/{drone_id}"
        },
        "_description": {
            "enabled": "是否启用真实无人机接入（预留配置）",
            "api_endpoints": "真实无人机可用的API接口",
            "_integration_guide": {
                "step1": "真实无人机启动时调用 register 接口注册",
                "step2": "每5秒调用 heartbeat 接口上报心跳（轻量级）",
                "step3": "每10秒调用 patrol_data 接口上报完整数据（触发告警）",
                "data_format": "JSON格式，详见API文档"
            }
        }
    },
    
    "cors_config": {
